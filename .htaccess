Options -Indexes
DirectorySlash Off

RewriteEngine On

# Highest precedence: /signal and /signal/ both serve signal.html. Without this,
# LiteSpeed sees the signal/ directory and 301-redirects /signal → /signal/, which
# then 403s because Options -Indexes blocks directory listing. Two rules cover
# both with-slash and without-slash entry points.
RewriteRule ^signal/?$ signal.html [NC,L]

# IC workshop June 25 (2026-06-12): registration page lives at /workshop/.
# Serve the directory index explicitly (DirectorySlash Off would otherwise
# send /workshop into the clean-URL rule and 404 on workshop.html).
RewriteRule ^workshop/?$ workshop/index.html [NC,L]
# A/B variant B of the workshop page (paid/ad traffic lands here via /w/ads).
# Same directory-index pattern as /workshop so /workshop-b and /workshop-b/ both serve.
RewriteRule ^workshop-b/?$ workshop-b/index.html [NC,L]

# IC lead-magnet opt-in (free AI checklist) lives at /ai-checklist/.
# Same directory-index pattern as /workshop. Captures cold Meta-ad traffic.
RewriteRule ^ai-checklist/?$ ai-checklist/index.html [NC,L]
# IC simple one-screen QR conversion page (StartFEST + /w/ss) lives at /seat/.
RewriteRule ^seat/?$ seat/index.html [NC,L]
# Customer-facing support + privacy pages (Stripe links point here). Same
# directory-index pattern as /workshop: DirectorySlash Off would otherwise send
# /support and /privacy into the clean-URL rule and 404 on support.html.
RewriteRule ^support/?$ support/index.html [NC,L]
RewriteRule ^privacy/?$ privacy/index.html [NC,L]
RewriteRule ^terms/?$ terms/index.html [NC,L]
# SW cold-email link consistency (2026-07-15): signature shows
# catalystworks.consulting/geolisted so recipients see one CW domain.
# Send them straight through to the geolisted.co landing page.
RewriteRule ^geolisted/?$ https://geolisted.co/ [R=301,L]
# Free ($0) Stripe checkout success page (after_completion redirect target for the
# $0 free-seat payment link). Confirms the free July 30 reservation.
RewriteRule ^free-thank-you/?$ free-thank-you/index.html [NC,L]
# The July 16 free session was CANCELLED and its page only hit Beehiiv while
# advertising a dead date. Repoint any straggler still holding an old
# SBDC-newsletter link straight to the live July 30 free-seat capture, which
# actually reserves the $0 seat (email captured + prefilled into the Stripe
# reservation). Organic medium keeps ad-spend attribution honest. The old
# HTML stays on disk but is unreachable via its canonical URL.
RewriteRule ^free-workshop-july16/?$ /ai-checklist/?utm_source=sbdc&utm_medium=organic&utm_campaign=ic_workshop_0730&utm_content=stale_july16_redirect [R=301,L]
# The July 30 comp-seat RSVP page booked NOTHING (Beehiiv-only) yet told
# visitors "your seat is held" -- a false claim. Repoint to the live free-seat
# capture that actually reserves the $0 seat. Organic medium keeps attribution
# honest. NOTE: /w/vip below still resolves here via a second 301 hop.
RewriteRule ^rsvp-0730/?$ /ai-checklist/?utm_source=direct_invite&utm_medium=organic&utm_campaign=ic_workshop_0730&utm_content=stale_rsvp0730_redirect [R=301,L]
# Short link for the lead-magnet (Meta ads + any channel): /w/start -> opt-in page.
# Campaign = stable magnet base; utm_content carries the current cohort for per-run segmentation.
RewriteRule ^w/start/?$ /ai-checklist/?utm_source=meta&utm_medium=paid&utm_campaign=ic_workshop_leadmagnet&utm_content=cohort:2026_06_25 [R=301,L,QSA]

# Workshop short links: one per channel, UTM baked behind the 301.
# Never reuse a slug across campaigns.
RewriteRule ^w/svc/?$ /workshop/?utm_source=chamber&utm_medium=email&utm_campaign=ic_workshop_0730&utm_content=south_valley [R=301,L,QSA]
RewriteRule ^w/sjc/?$ /workshop/?utm_source=chamber&utm_medium=email&utm_campaign=ic_workshop_0730&utm_content=south_jordan [R=301,L,QSA]
RewriteRule ^w/li/?$ /workshop/?utm_source=linkedin&utm_medium=post&utm_campaign=ic_workshop_0730 [R=301,L,QSA]
RewriteRule ^w/x/?$ /workshop/?utm_source=x&utm_medium=post&utm_campaign=ic_workshop_0730 [R=301,L,QSA]
RewriteRule ^w/nl/?$ /workshop/?utm_source=newsletter&utm_medium=email&utm_campaign=ic_workshop_0730 [R=301,L,QSA]
# SPLIT TEST (July 30 workshop) -- two paid Meta tracks under one campaign,
# distinguished by utm_content so seats are attributable per track.
# Track 1 DIRECT: cold ad -> $47 seat page (variant B). utm_content=track_direct.
RewriteRule ^w/ads/?$ /workshop-b/?utm_source=meta&utm_medium=paid&utm_campaign=ic_workshop_0730&utm_content=track_direct [R=301,L,QSA]
# Track 2 FREE-FIRST: cold ad -> free AI checklist (email capture + Meta Lead)
# then its built-in CTA to the $47 July 30 seat. utm_content=track_free.
RewriteRule ^w/free/?$ /ai-checklist/?utm_source=meta&utm_medium=paid&utm_campaign=ic_workshop_0730&utm_content=track_free [R=301,L,QSA]
RewriteRule ^w/fb/?$ /ai-checklist/?utm_source=facebook&utm_medium=paid&utm_campaign=ic_workshop_leadmagnet&utm_content=fb_ad [R=301,L,QSA]

# ORGANIC free-seat link -- for a hand-posted FB/social post, NOT an ad buy.
# Exists because every /w/ free-seat slug above bakes utm_medium=paid: sharing
# one in an organic post logs the click as paid Meta traffic and corrupts the
# ad-spend read. This is the attribution-honest slug for anything Boubacar
# posts by hand.
# utm_content MUST NOT contain the substring "track_free": /workshop/ and
# /workshop-b/ attribute the split test with /track_free/.test(utm_content),
# so a value like "track_free_organic" would silently register organic clicks
# as the paid free-first arm. "organic_fb" cannot match, which is the point.
RewriteRule ^w/fb-organic/?$ /ai-checklist/?utm_source=facebook&utm_medium=organic&utm_campaign=ic_workshop_0730&utm_content=organic_fb [R=301,L,QSA]

# Paid-seat counterpart to /w/free. Was a 404, which is a trap: the free line
# had a short link and the paid line did not. Direct/hand-shared attribution,
# no channel baked in -- the per-channel paid slugs above stay the way to
# attribute a specific campaign.
RewriteRule ^w/paid/?$ /workshop/?utm_source=direct&utm_medium=link&utm_campaign=ic_workshop_0730&utm_content=direct_paid [R=301,L,QSA]

RewriteRule ^w/sbdc/?$ /workshop/?utm_source=sbdc&utm_medium=partner&utm_campaign=ic_workshop_0730 [R=301,L,QSA]
RewriteRule ^w/beccy/?$ /workshop/?utm_source=beccy&utm_medium=email&utm_campaign=ic_workshop_0730 [R=301,L,QSA]
RewriteRule ^w/ss/?$ /seat/?utm_source=silicon_slopes&utm_medium=event&utm_campaign=ic_workshop_0730 [R=301,L,QSA]

# Old SBDC-newsletter short link for the CANCELLED July 16 free session. Its old
# target (/free-workshop-july16/) now 301s to the live July 30 free-seat capture;
# point this straight there too so a straggler clicking the old newsletter link
# lands on the working capture in a single hop, not a double 301.
RewriteRule ^w/july16/?$ /ai-checklist/?utm_source=sbdc&utm_medium=organic&utm_campaign=ic_workshop_0730&utm_content=stale_july16_shortlink [R=301,L]

# DISCRETE comp-seat link for July 30 -- Boubacar shares this 1:1 only (never
# posted publicly, never linked from the paid page). Confirms a free seat with
# NO Stripe charge; fires a CompleteRegistration pixel event so comps stay
# separable from paid Purchase and free-track Lead events.
RewriteRule ^w/vip/?$ /rsvp-0730/?utm_source=direct_invite&utm_medium=comp&utm_campaign=ic_workshop_0730&utm_content=track_comp [R=301,L,QSA]

# Clean URLs: append .html for any path without an extension. Handles top-level
# (/governance → /governance.html), nested (/lens/throughput → /lens/throughput.html,
# /for/hvac → /for/hvac.html, /signal/issue-3 → /signal/issue-3.html), and arbitrary
# depth. The character class [^\.]+ matches across "/" because slashes are not dots.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^\.]+)$ $1.html [NC,L]

# Force browsers to revalidate HTML + CSS on every load so style/layout fixes
# propagate immediately rather than living in client caches for hours.
# Static assets (images, fonts) keep long TTL via default LiteSpeed behavior.
<FilesMatch "\.(html|htm|css)$">
  Header set Cache-Control "no-cache, must-revalidate, max-age=0"
</FilesMatch>
