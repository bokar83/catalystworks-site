Options -Indexes

RewriteEngine On

# Clean URLs: /signal -> /signal.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^\.]+)$ $1.html [NC,L]

# Signal archive subfolder: /signal/issue-3 -> /signal/issue-3.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^signal/([^\.]+)$ signal/$1.html [NC,L]
